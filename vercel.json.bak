{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },

    { "source": "/@vite/(.*)", "destination": "/@vite/$1" },
    { "source": "/@react-refresh", "destination": "/@react-refresh" },
    { "source": "/@fs/(.*)", "destination": "/@fs/$1" },
    { "source": "/src/(.*)", "destination": "/src/$1" },

    { "source": "/(.*)", "destination": "/" }
  ]
}