{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/cron-sync.ts": {
      "maxDuration": 60
    },
    "api/cron-monitoring.ts": {
      "maxDuration": 60
    },
    "api/sync-analytics.ts": {
      "maxDuration": 60
    },
    "api/displayforce-led.ts": {
      "maxDuration": 60
    },
    "api/lia-chat.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
